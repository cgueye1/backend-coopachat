# ═══════════════════════════════════════════════════════════════════════════
# Base MySQL — utilisé par docker-compose (service db) et par Spring (profil docker)
# ═══════════════════════════════════════════════════════════════════════════
DB_NAME=coopachat
DB_USER=root
DB_PASSWORD=rootpass
DB_ROOT_PASSWORD=rootpass

JWT_SECRET=coopachat-secret-key-256-bits-minimum-required-for-security-2025

# ═══════════════════════════════════════════════════════════════════════════
# SMTP — envoi des mails (OTP, reset MDP, etc.)
# ═══════════════════════════════════════════════════════════════════════════
# Hôte SMTP (Gmail, Brevo, etc.)
MAIL_HOST=smtp.gmail.com
# 587 = soumission avec STARTTLS
MAIL_PORT=587
# Compte / expéditeur pour l’auth SMTP
MAIL_USERNAME=coopachat2026@gmail.com
MAIL_PASSWORD=

MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_SMTP_STARTTLS_REQUIRED=true
MAIL_SMTP_SSL_TRUST=smtp.gmail.com

# ═══════════════════════════════════════════════════════════════════════════
# Front Angular — liens dans les e-mails
# ═══════════════════════════════════════════════════════════════════════════
# En production : remplacer par https://votre-domaine.fr (pas localhost)
FRONTEND_BASE_URL=http://localhost:4200
FRONTEND_RESET_PASSWORD_URL=http://localhost:4200/create-password?token=
FRONTEND_RESET_PASSWORD_URL_MOBILE=coopachat://reset-password/

# ═══════════════════════════════════════════════════════════════════════════
# MinIO — fichiers / images
# ═══════════════════════════════════════════════════════════════════════════
MINIO_URL=https://minio.innovimpactafrica.cloud
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=coop-achat

# ═══════════════════════════════════════════════════════════════════════════
# Déploiement sans Docker Compose (ex. Dockploy)
# ═══════════════════════════════════════════════════════════════════════════
# SPRING_PROFILES_ACTIVE=docker
# URL JDBC vers la vraie base (hôte fourni par l’hébergeur, pas "db")
# SPRING_DATASOURCE_URL=jdbc:mysql://VOTRE_HOTE:3306/coopachat?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true&characterEncoding=UTF-8&connectionCollation=utf8mb4_unicode_ci
