spring.application.name=coopachat
spring.datasource.url=jdbc:mysql://localhost:3307/coopachat?useSSL=false&serverTimezone=UTC
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect

spring.datasource.username=####
spring.datasource.password=####
server.port=8082


spring.jpa.hibernate.ddl-auto=update
springdoc.api-docs.path=/v3/api-docs
springdoc.swagger-ui.path=/swagger-ui.html

# Clé secrète du token
jwt.secret=coopachat-secret-key-256-bits-minimum-required-for-security-2025

#Temps d'expiration du token 24heures par défaut
jwt.expiration=86400000

#Temps d'expiration du code d'activation lors de l'inscription
activation.code.expiration.minutes=15

# ============================================================================
# 📧 CONFIGURATION EMAIL
# ============================================================================

# Configuration Email Gmail
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=${MAIL_USERNAME:your-email@gmail.com}
spring.mail.password=${MAIL_PASSWORD:your-app-password}
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.ssl.trust=smtp.gmail.com

# Configuration des emails
mail.from=${MAIL_FROM:admincoopachat@yopmail.com}
mail.app.name=CoopAchat

# Frontend base URL used in emails
app.frontend.base-url=http://localhost:4200

# Frontend URLs complètes (sans le token, qui sera ajouté dynamiquement)
app.frontend.reset-password-url=http://localhost:4200/reset-password?token=
app.frontend.activate-employee-url=http://localhost:4200/activate?token=


#Compte à rebours
activation.code.resend.cooldown.seconds= 30